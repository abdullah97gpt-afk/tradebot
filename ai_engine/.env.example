# Copy this file to .env and fill in your values
# NEVER commit .env to version control

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Alpha Vantage key (free at alphavantage.co)
# Leave blank to use synthetic demo data
MARKET_DATA_API_KEY=your-alpha-vantage-key

# Prefix with "td:" for Twelve Data instead of Alpha Vantage
# MARKET_DATA_API_KEY=td:your-twelve-data-key

# Optional: NewsAPI key (free at newsapi.org)
NEWS_API_KEY=your-newsapi-key

# Optional
LOG_LEVEL=INFO
